---
import CodeBlock from './CodeBlock.astro';
---

<section class="relative overflow-hidden">
  <!-- Background grid effect -->
  <div class="absolute inset-0 bg-[linear-gradient(rgba(0,212,255,0.03)_1px,transparent_1px),linear-gradient(90deg,rgba(0,212,255,0.03)_1px,transparent_1px)] bg-[size:60px_60px]"></div>
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[800px] h-[600px] bg-accent/5 rounded-full blur-[120px]"></div>

  <div class="relative max-w-5xl mx-auto px-6 pt-24 pb-20">
    <!-- Logo / Wordmark -->
    <div class="flex items-center justify-center gap-3 mb-10">
      <div class="w-10 h-10 rounded-lg bg-accent/10 border border-accent/20 flex items-center justify-center">
        <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
            d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
        </svg>
      </div>
      <span class="text-2xl font-bold tracking-tight text-text-primary font-mono">parapilot</span>
    </div>

    <!-- Headline -->
    <h1 class="text-center text-4xl sm:text-5xl md:text-6xl font-extrabold tracking-tight leading-tight mb-4">
      <span class="text-text-primary">AI가 CFD를 </span>
      <span class="text-accent">렌더링</span>
      <span class="text-text-primary">한다</span>
    </h1>

    <p class="text-center text-lg sm:text-xl text-text-secondary max-w-2xl mx-auto mb-3">
      Headless ParaView MCP Server for AI Coding Assistants
    </p>

    <!-- Stats -->
    <div class="flex items-center justify-center gap-4 sm:gap-6 mb-10 text-sm font-mono">
      <span class="text-accent">13 tools</span>
      <span class="text-border">&middot;</span>
      <span class="text-accent">9 resources</span>
      <span class="text-border">&middot;</span>
      <span class="text-accent">146 tests</span>
    </div>

    <!-- Terminal install -->
    <div class="max-w-lg mx-auto mb-8">
      <CodeBlock code="pip install mcp-server-parapilot" lang="bash" />
    </div>

    <!-- Badges -->
    <div class="flex items-center justify-center flex-wrap gap-3 mb-14">
      <a href="https://github.com/kimimgo/parapilot" target="_blank" rel="noopener noreferrer"
         class="inline-flex items-center gap-2 px-4 py-2 rounded-full border border-border bg-secondary
                text-text-secondary text-sm hover:border-accent/40 hover:text-text-primary transition-all">
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z" />
        </svg>
        GitHub
      </a>
      <a href="https://pypi.org/project/mcp-server-parapilot/" target="_blank" rel="noopener noreferrer"
         class="inline-flex items-center gap-2 px-4 py-2 rounded-full border border-border bg-secondary
                text-text-secondary text-sm hover:border-accent/40 hover:text-text-primary transition-all">
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
          <path d="M9.585 11.692h4.328s2.432.039 2.432-2.35V5.391S16.714 3 11.936 3C7.362 3 7.647 4.983 7.647 4.983l.006 2.055h4.363v.617H7.14S4.5 7.28 4.5 11.85c0 4.571 2.317 4.406 2.317 4.406h1.384v-2.127s-.075-2.317 2.301-2.317l.083-.12zM9.345 5.246a.755.755 0 11-.002 1.51.755.755 0 01.002-1.51z" />
          <path d="M14.415 12.308h-4.328s-2.432-.039-2.432 2.35v3.951s-.369 2.391 4.409 2.391c4.573 0 4.288-1.983 4.288-1.983l-.006-2.055h-4.363v-.617h4.876s2.639.375 2.639-4.195c0-4.571-2.317-4.406-2.317-4.406h-1.384v2.127s.075 2.317-2.301 2.317l-.081.12zm.24 5.446a.755.755 0 110 1.51.755.755 0 010-1.51z" />
        </svg>
        PyPI
      </a>
      <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full border border-border bg-secondary
                    text-text-secondary text-sm">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
            d="M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l-3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3" />
        </svg>
        MIT License
      </span>
    </div>

    <!-- Demo placeholder -->
    <div class="max-w-3xl mx-auto rounded-xl border border-border bg-secondary overflow-hidden glow-accent">
      <div class="flex items-center gap-2 px-4 py-2.5 border-b border-border">
        <div class="flex gap-1.5">
          <span class="w-3 h-3 rounded-full bg-[#ff5f57]"></span>
          <span class="w-3 h-3 rounded-full bg-[#febc2e]"></span>
          <span class="w-3 h-3 rounded-full bg-[#28c840]"></span>
        </div>
        <span class="text-xs text-text-secondary font-mono ml-2">parapilot render output</span>
      </div>
      <div class="aspect-video bg-gradient-to-br from-tertiary via-secondary to-primary flex items-center justify-center">
        <div class="text-center">
          <div class="w-20 h-20 mx-auto mb-4 rounded-2xl bg-accent/10 border border-accent/20 flex items-center justify-center">
            <svg class="w-10 h-10 text-accent/60" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
          </div>
          <p class="text-text-secondary text-sm">CFD pressure field + streamline visualization</p>
          <p class="text-text-secondary/50 text-xs mt-1">Rendered by parapilot</p>
        </div>
      </div>
    </div>
  </div>
</section>
