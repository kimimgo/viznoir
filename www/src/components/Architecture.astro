---
const layers = [
  {
    level: 'Layer 3',
    name: 'Skills',
    items: ['cfd-postprocess', 'mesh-inspect', 'report-generate'],
    desc: 'Natural language interface — high-level workflows that AI understands',
    accent: true,
  },
  {
    level: 'Layer 2',
    name: 'Agents',
    items: ['viz-agent (sonnet)', 'mesh-agent (haiku)'],
    desc: 'Specialized sub-agents — split visualization and mesh analysis',
    accent: true,
  },
  {
    level: 'Layer 1',
    name: 'MCP Server',
    items: ['18 Tools', '11 Resources', '3 Prompts'],
    desc: 'MCP protocol — VTK direct API, meshio, trimesh engine',
    accent: true,
  },
  {
    level: 'Infra',
    name: 'Infrastructure',
    items: ['Docker (EGL GPU / OSMesa CPU)', '50+ formats', 'VTK 9.4'],
    desc: 'GPU acceleration or CPU fallback, 50+ file formats supported',
    accent: false,
  },
];
---

<section class="relative py-28 bg-secondary/20">
  <div class="max-w-6xl mx-auto px-6">
    <div class="text-center mb-16 fade-up">
      <span class="inline-block px-3 py-1 rounded-full bg-accent/10 text-accent text-xs font-mono font-medium tracking-wider mb-4">
        ARCHITECTURE
      </span>
      <h2 class="text-3xl sm:text-4xl md:text-5xl font-bold tracking-tight">
        <span class="gradient-text-white">3-Layer Architecture</span>
      </h2>
      <p class="mt-4 text-text-secondary max-w-xl mx-auto text-lg">
        Each layer scales independently as a plugin
      </p>
    </div>

    <div class="max-w-2xl mx-auto space-y-3 fade-up">
      {layers.map((layer, index) => (
        <div>
          <div class="card-hover p-5 group !rounded-xl">
            <div class="flex items-center gap-3 mb-3">
              <span class={`text-xs font-mono font-semibold tracking-wider uppercase ${layer.accent ? 'text-accent/50' : 'text-text-secondary/30'}`}>
                {layer.level}
              </span>
              <span class="text-lg font-bold text-text-primary">{layer.name}</span>
            </div>

            <div class="flex flex-wrap gap-2 mb-2">
              {layer.items.map((item) => (
                <span class="px-3 py-1 rounded-lg bg-primary/80 border border-border/50 text-xs font-mono text-text-secondary/70">
                  {item}
                </span>
              ))}
            </div>

            <p class="text-sm text-text-secondary/40 group-hover:text-text-secondary/70 transition-colors">
              {layer.desc}
            </p>
          </div>

          {index < layers.length - 1 && (
            <div class="flex justify-center py-1">
              <svg class="w-4 h-4 text-accent/20" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
              </svg>
            </div>
          )}
        </div>
      ))}
    </div>
  </div>
</section>
