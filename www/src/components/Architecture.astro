---
const layers = [
  {
    level: 'Layer 3',
    name: 'Skills',
    color: 'accent',
    items: ['cfd-postprocess', 'mesh-inspect', 'report-generate'],
    description: '자연어 인터페이스 — AI가 이해하는 고수준 워크플로우',
  },
  {
    level: 'Layer 2',
    name: 'Agents',
    color: 'accent',
    items: ['viz-agent (sonnet)', 'mesh-agent (haiku)'],
    description: '전문 서브에이전트 — 시각화와 메시 분석을 분담',
  },
  {
    level: 'Layer 1',
    name: 'MCP Server',
    color: 'accent',
    items: ['13 Tools', '9 Resources', '3 Prompts'],
    description: 'MCP 프로토콜 — pvpython, meshio, trimesh 엔진',
  },
  {
    level: 'Infra',
    name: 'Infrastructure',
    color: 'text-secondary',
    items: ['Docker (EGL GPU / OSMesa CPU)', '50+ formats', 'ParaView 5.13'],
    description: 'GPU 가속 또는 CPU 폴백, 50개 이상 파일 형식 지원',
  },
];
---

<section class="relative py-24 bg-secondary/30">
  <div class="max-w-5xl mx-auto px-6">
    <!-- Section header -->
    <div class="text-center mb-16">
      <span class="inline-block px-3 py-1 rounded-full bg-accent/10 text-accent text-xs font-mono font-medium tracking-wide mb-4">
        ARCHITECTURE
      </span>
      <h2 class="text-3xl sm:text-4xl font-bold tracking-tight text-text-primary">
        3-Layer 아키텍처
      </h2>
      <p class="mt-3 text-text-secondary max-w-xl mx-auto">
        스킬에서 인프라까지, 각 레이어가 독립적으로 확장 가능
      </p>
    </div>

    <!-- Layer stack -->
    <div class="max-w-2xl mx-auto space-y-4">
      {layers.map((layer, index) => (
        <div>
          <div class="group relative rounded-xl border border-border bg-tertiary p-5
                      hover:border-accent/30 hover:glow-accent transition-all duration-300">
            <div class="flex flex-col sm:flex-row sm:items-center gap-3 mb-3">
              <span class="text-xs font-mono font-semibold text-accent/60 tracking-wider uppercase">
                {layer.level}
              </span>
              <h3 class="text-lg font-bold text-text-primary">{layer.name}</h3>
            </div>

            <!-- Items as tags -->
            <div class="flex flex-wrap gap-2 mb-3">
              {layer.items.map((item) => (
                <span class="px-3 py-1 rounded-md bg-primary border border-border text-sm font-mono text-text-secondary">
                  {item}
                </span>
              ))}
            </div>

            <p class="text-sm text-text-secondary/70 group-hover:text-text-secondary transition-colors">
              {layer.description}
            </p>
          </div>

          {/* Arrow between layers */}
          {index < layers.length - 1 && (
            <div class="flex justify-center py-1">
              <svg class="w-5 h-5 text-accent/30" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
              </svg>
            </div>
          )}
        </div>
      ))}
    </div>
  </div>
</section>
