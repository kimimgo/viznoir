---

<section class="relative py-28">
  <div class="section-divider mb-28"></div>
  <div class="max-w-6xl mx-auto px-6">
    <div class="text-center mb-16 fade-up">
      <span class="inline-block px-3 py-1 rounded-full bg-accent/10 text-accent text-xs font-mono font-medium tracking-wider mb-4">
        SHOWCASE
      </span>
      <h2 class="text-3xl sm:text-4xl md:text-5xl font-bold tracking-tight">
        <span class="gradient-text-white">Real renders, zero GUI</span>
      </h2>
      <p class="mt-4 text-text-secondary max-w-xl mx-auto text-lg">
        13 engineering domains, 25+ datasets — multi-view, volume, surface, animation across all CAE fields
      </p>
    </div>

    <!-- Featured render (large) -->
    <div class="mb-8 fade-up">
      <div class="card-hover overflow-hidden group cursor-default">
        <div class="relative aspect-video">
          <picture>
            <source srcset={renders[0].src.replace('.png', '.webp')} type="image/webp" />
            <img
              src={renders[0].src}
              alt={renders[0].title}
              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-[1.02]"
              loading="lazy"
            />
          </picture>
          <div class="absolute inset-0 bg-gradient-to-t from-primary/90 via-transparent to-transparent"></div>
          <div class="absolute bottom-0 left-0 right-0 p-6 sm:p-8">
            <div class="flex items-center gap-3 mb-2">
              <span class="px-2.5 py-0.5 rounded-full bg-accent/20 text-accent text-xs font-mono">
                {renders[0].tool}
              </span>
              <span class="text-xs text-text-secondary/60 font-mono">{renders[0].field}</span>
            </div>
            <h3 class="text-xl sm:text-2xl font-bold text-text-primary">{renders[0].title}</h3>
            <p class="text-sm text-text-secondary mt-1">{renders[0].desc}</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Grid of remaining renders -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 fade-up">
      {renders.slice(1).map((r) => (
        <div class="card-hover overflow-hidden group cursor-default">
          <div class="relative aspect-video">
            <picture>
              <source srcset={r.src.replace('.png', '.webp')} type="image/webp" />
              <img
                src={r.src}
                alt={r.title}
                class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-[1.02]"
                loading="lazy"
              />
            </picture>
            <div class="absolute inset-0 bg-gradient-to-t from-primary/80 via-transparent to-transparent"></div>
            <div class="absolute bottom-0 left-0 right-0 p-4">
              <span class="inline-block px-2 py-0.5 rounded-full bg-accent/20 text-accent text-[10px] font-mono mb-1.5">
                {r.tool}
              </span>
              <h3 class="text-sm font-semibold text-text-primary">{r.title}</h3>
              <p class="text-xs text-text-secondary/70 mt-0.5">{r.desc}</p>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Multi-View Analysis showcase -->
    <div class="mt-16 fade-up">
      <div class="text-center mb-8">
        <span class="inline-block px-3 py-1 rounded-full bg-accent/10 text-accent text-xs font-mono font-medium tracking-wider mb-3">
          MULTI-VIEW ANALYSIS
        </span>
        <h3 class="text-2xl sm:text-3xl font-bold tracking-tight">
          <span class="gradient-text-white">One dataset, four perspectives</span>
        </h3>
        <p class="mt-3 text-text-secondary max-w-lg mx-auto">
          Comprehensive scientific analysis — contour, volume, slice, and line profile from a single dataset
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {multiview.map((m) => (
          <div class="card-hover overflow-hidden group cursor-default">
            <div class="relative">
              <picture>
                <source srcset={m.src.replace('.png', '.webp')} type="image/webp" />
                <img
                  src={m.src}
                  alt={m.title}
                  class="w-full h-auto transition-transform duration-500 group-hover:scale-[1.02]"
                  loading="lazy"
                />
              </picture>
              <div class="absolute inset-0 bg-gradient-to-t from-primary/80 via-transparent to-transparent"></div>
              <div class="absolute top-3 right-3">
                <span class="px-2 py-0.5 rounded-full bg-purple-500/30 text-purple-400 text-[10px] font-mono backdrop-blur-sm">
                  4-VIEW
                </span>
              </div>
              <div class="absolute bottom-0 left-0 right-0 p-4">
                <div class="flex flex-wrap gap-1 mb-1.5">
                  {m.tools.map((t: string) => (
                    <span class="inline-block px-1.5 py-0.5 rounded-full bg-accent/20 text-accent text-[9px] font-mono">
                      {t}
                    </span>
                  ))}
                </div>
                <h3 class="text-sm font-semibold text-text-primary">{m.title}</h3>
                <p class="text-xs text-text-secondary/70 mt-0.5">{m.desc}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Engineering Domains showcase -->
    <div class="mt-16 fade-up">
      <div class="text-center mb-8">
        <span class="inline-block px-3 py-1 rounded-full bg-accent/10 text-accent text-xs font-mono font-medium tracking-wider mb-3">
          13 ENGINEERING DOMAINS
        </span>
        <h3 class="text-2xl sm:text-3xl font-bold tracking-tight">
          <span class="gradient-text-white">From ocean to outer space</span>
        </h3>
        <p class="mt-3 text-text-secondary max-w-lg mx-auto">
          Marine, mechanical, aero, electronics, biomedical, geoscience, environmental, chemical, structural, naval, aerospace, and urban engineering
        </p>
      </div>

      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-3">
        {domains.map((d) => (
          <div class="card-hover overflow-hidden group cursor-default">
            <div class="relative">
              <picture>
                <source srcset={d.src.replace('.png', '.webp')} type="image/webp" />
                <img
                  src={d.src}
                  alt={d.title}
                  class="w-full h-auto transition-transform duration-500 group-hover:scale-[1.02]"
                  loading="lazy"
                />
              </picture>
              <div class="absolute inset-0 bg-gradient-to-t from-primary/80 via-transparent to-transparent"></div>
              <div class="absolute top-2 right-2">
                <span class="px-1.5 py-0.5 rounded-full bg-cyan-500/30 text-cyan-400 text-[9px] font-mono backdrop-blur-sm">
                  {d.domain}
                </span>
              </div>
              <div class="absolute bottom-0 left-0 right-0 p-3">
                <h3 class="text-xs font-semibold text-text-primary leading-tight">{d.title}</h3>
                <p class="text-[10px] text-text-secondary/70 mt-0.5 leading-tight">{d.desc}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Animation showcase -->
    <div class="mt-16 fade-up">
      <div class="text-center mb-8">
        <span class="inline-block px-3 py-1 rounded-full bg-accent/10 text-accent text-xs font-mono font-medium tracking-wider mb-3">
          ANIMATIONS
        </span>
        <h3 class="text-2xl sm:text-3xl font-bold tracking-tight">
          <span class="gradient-text-white">Animate, sweep, orbit</span>
        </h3>
        <p class="mt-3 text-text-secondary max-w-lg mx-auto">
          Slice sweeps and 360° orbit animations generated programmatically — GIF, MP4, or WebM
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-3 gap-5">
        {animations.map((a) => (
          <div class="card-hover overflow-hidden group cursor-default">
            <div class="relative aspect-video">
              <picture>
                <source srcset={a.webp} type="image/webp" />
                <img
                  src={a.gif}
                  alt={a.title}
                  class="w-full h-full object-cover"
                  loading="lazy"
                />
              </picture>
              <div class="absolute inset-0 bg-gradient-to-t from-primary/80 via-transparent to-transparent"></div>
              <div class="absolute top-3 right-3">
                <span class="px-2 py-0.5 rounded-full bg-accent/30 text-accent text-[10px] font-mono backdrop-blur-sm">
                  ANIMATED
                </span>
              </div>
              <div class="absolute bottom-0 left-0 right-0 p-4">
                <span class="inline-block px-2 py-0.5 rounded-full bg-accent/20 text-accent text-[10px] font-mono mb-1.5">
                  {a.tool}
                </span>
                <h3 class="text-sm font-semibold text-text-primary">{a.title}</h3>
                <p class="text-xs text-text-secondary/70 mt-0.5">{a.desc}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- HD Video showcase -->
    <div class="mt-16 fade-up">
      <div class="text-center mb-8">
        <span class="inline-block px-3 py-1 rounded-full bg-accent/10 text-accent text-xs font-mono font-medium tracking-wider mb-3">
          1080p VIDEO
        </span>
        <h3 class="text-2xl sm:text-3xl font-bold tracking-tight">
          <span class="gradient-text-white">Full HD, headless render</span>
        </h3>
        <p class="mt-3 text-text-secondary max-w-lg mx-auto">
          1920&times;1080 orbit at 30fps — rendered in &lt;15 seconds per video
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
        {videos.map((v) => (
          <div class="card-hover overflow-hidden group cursor-default">
            <div class="relative aspect-video">
              <video
                autoplay
                loop
                muted
                playsinline
                poster={v.poster}
                class="w-full h-full object-cover"
              >
                <source src={v.webm} type="video/webm" />
                <source src={v.mp4} type="video/mp4" />
              </video>
              <div class="absolute inset-0 bg-gradient-to-t from-primary/80 via-transparent to-transparent pointer-events-none"></div>
              <div class="absolute top-3 right-3">
                <span class="px-2 py-0.5 rounded-full bg-accent/30 text-accent text-[10px] font-mono backdrop-blur-sm">
                  1080p
                </span>
              </div>
              <div class="absolute bottom-0 left-0 right-0 p-4">
                <span class="inline-block px-2 py-0.5 rounded-full bg-accent/20 text-accent text-[10px] font-mono mb-1.5">
                  {v.tool}
                </span>
                <h3 class="text-sm font-semibold text-text-primary">{v.title}</h3>
                <p class="text-xs text-text-secondary/70 mt-0.5">{v.desc}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- MCP Tools in Action -->
    <div class="mt-16 fade-up">
      <div class="text-center mb-8">
        <span class="inline-block px-3 py-1 rounded-full bg-accent/10 text-accent text-xs font-mono font-medium tracking-wider mb-3">
          MCP TOOLS IN ACTION
        </span>
        <h3 class="text-2xl sm:text-3xl font-bold tracking-tight">
          <span class="gradient-text-white">One tool call, one render</span>
        </h3>
        <p class="mt-3 text-text-secondary max-w-lg mx-auto">
          Each image below is the direct output of a single MCP tool call — no post-processing
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {mcpTools.map((m) => (
          <div class="card-hover overflow-hidden group cursor-default">
            <div class="relative">
              <picture>
                <source srcset={m.src.replace('.png', '.webp')} type="image/webp" />
                <img
                  src={m.src}
                  alt={m.title}
                  class="w-full h-auto transition-transform duration-500 group-hover:scale-[1.02]"
                  loading="lazy"
                />
              </picture>
              <div class="absolute inset-0 bg-gradient-to-t from-primary/90 via-primary/20 to-transparent"></div>
              <div class="absolute top-3 right-3">
                <span class="px-2 py-0.5 rounded-full bg-accent/30 text-accent text-[10px] font-mono backdrop-blur-sm">
                  E2E
                </span>
              </div>
              <div class="absolute bottom-0 left-0 right-0 p-4">
                <span class="inline-block px-2 py-0.5 rounded-full bg-accent/20 text-accent text-[10px] font-mono mb-1.5">
                  parapilot.{m.title}
                </span>
                <p class="text-xs text-text-secondary/70 mt-0.5">{m.desc}</p>
                <code class="block text-[10px] text-accent/50 font-mono mt-1.5 truncate">{m.call}</code>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Data Analysis showcase -->
    <div class="mt-16 fade-up">
      <div class="text-center mb-8">
        <span class="inline-block px-3 py-1 rounded-full bg-accent/10 text-accent text-xs font-mono font-medium tracking-wider mb-3">
          DATA ANALYSIS
        </span>
        <h3 class="text-2xl sm:text-3xl font-bold tracking-tight">
          <span class="gradient-text-white">Beyond rendering</span>
        </h3>
        <p class="mt-3 text-text-secondary max-w-lg mx-auto">
          Extract quantitative data from simulations — line plots, statistics, surface integrals
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
        {analysis.map((a) => (
          <div class="card-hover overflow-hidden group cursor-default">
            <div class="relative">
              <picture>
                <source srcset={a.src.replace('.png', '.webp')} type="image/webp" />
                <img
                  src={a.src}
                  alt={a.title}
                  class="w-full h-auto transition-transform duration-500 group-hover:scale-[1.02]"
                  loading="lazy"
                />
              </picture>
              <div class="absolute inset-0 bg-gradient-to-t from-primary/80 via-transparent to-transparent"></div>
              <div class="absolute top-3 right-3">
                <span class="px-2 py-0.5 rounded-full bg-emerald-500/30 text-emerald-400 text-[10px] font-mono backdrop-blur-sm">
                  DATA
                </span>
              </div>
              <div class="absolute bottom-0 left-0 right-0 p-4">
                <span class="inline-block px-2 py-0.5 rounded-full bg-accent/20 text-accent text-[10px] font-mono mb-1.5">
                  {a.tool}
                </span>
                <h3 class="text-sm font-semibold text-text-primary">{a.title}</h3>
                <p class="text-xs text-text-secondary/70 mt-0.5">{a.desc}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>

    <div class="text-center mt-10">
      <p class="text-text-secondary/50 text-sm font-mono">
        render &middot; contour &middot; streamlines &middot; clip &middot; slice &middot; animate &middot; split_animate &middot; extract_stats &middot; plot_over_line &mdash; 13 tools, 25+ datasets, 13 domains, 14 colormaps
      </p>
    </div>
  </div>
</section>
