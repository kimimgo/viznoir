  },
  {
    src: '/parapilot/showcase/mcp_slice.png',
    title: 'slice',
    desc: 'CT brain axial — auto-center origin, Grayscale',
    call: 'parapilot.slice(file="head.vti", field="MetaImage")',
  },
  {
    src: '/parapilot/showcase/mcp_clip.png',
    title: 'clip',
    desc: 'LiDAR terrain clipped at center — 3.4M points',
