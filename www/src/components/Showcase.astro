const analysis = [
  {
    src: '/parapilot/showcase/ct_density_profile.png',
    title: 'CT Density Profile',
    tool: 'parapilot.plot_over_line',
    desc: '6.16M voxels — Sagittal density sampling, bone/tissue threshold markers',
    field: 'head.vti',
  },
  {
    src: '/parapilot/showcase/extract_stats.png',
    title: 'Dataset Statistics',
