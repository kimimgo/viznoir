    desc: 'Batch analysis — 4 datasets, point/cell counts, field ranges',
    field: 'multiple',
  },
];

const videos = [
  {
    mp4: '/parapilot/showcase/dragon_orbit_hd.mp4',
    webm: '/parapilot/showcase/dragon_orbit_hd.webm',
    poster: '/parapilot/showcase/dragon.png',
    title: 'Dragon — 1080p Orbit',
    tool: 'parapilot.animate',
    desc: '871K cells, 60 frames @ 30fps, 185ms/frame render',
    field: 'dragon.ply',
  },
  {
    mp4: '/parapilot/showcase/ct_skull_orbit_hd.mp4',
    webm: '/parapilot/showcase/ct_skull_orbit_hd.webm',
    poster: '/parapilot/showcase/ct_head_contour.png',
    title: 'CT Skull — 1080p Orbit',
    tool: 'parapilot.animate',
