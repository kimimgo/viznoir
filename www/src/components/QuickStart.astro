---
import CodeBlock from './CodeBlock.astro';

const steps = [
  {
    num: '01',
    title: 'Install',
    desc: 'pip 한 줄로 설치',
    code: 'pip install mcp-server-parapilot',
    lang: 'bash',
  },
  {
    num: '02',
    title: 'Configure',
    desc: 'MCP 설정에 서버 추가',
    code: `{
  "mcpServers": {
    "parapilot": {
      "command": "mcp-server-parapilot"
    }
  }
}`,
    lang: 'json',
    filename: '.mcp.json',
  },
  {
    num: '03',
    title: 'Prompt',
    desc: '자연어로 후처리 실행',
    code: `"Show the pressure contour
of the cavity case"`,
    lang: 'text',
  },
];
---

<section class="relative py-28">
  <div class="section-divider mb-28"></div>
  <div class="max-w-6xl mx-auto px-6">
    <div class="text-center mb-16">
      <span class="inline-block px-3 py-1 rounded-full bg-accent/10 text-accent text-xs font-mono font-medium tracking-wider mb-4">
        QUICK START
      </span>
      <h2 class="text-3xl sm:text-4xl md:text-5xl font-bold tracking-tight">
        <span class="gradient-text-white">3단계로 시작</span>
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
      {steps.map((step) => (
        <div class="card-hover p-6">
          <div class="flex items-center gap-3 mb-4">
            <span class="text-3xl font-extrabold text-accent/15 font-mono">{step.num}</span>
            <h3 class="text-lg font-semibold text-text-primary">{step.title}</h3>
          </div>
          <p class="text-sm text-text-secondary/70 mb-4">{step.desc}</p>
          <CodeBlock code={step.code} lang={step.lang} filename={step.filename} />
        </div>
      ))}
    </div>
  </div>
</section>
