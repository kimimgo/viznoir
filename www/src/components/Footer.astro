---
const links = [
  { label: 'GitHub', href: 'https://github.com/kimimgo/viznoir' },
  { label: 'PyPI', href: 'https://pypi.org/project/mcp-server-viznoir/' },
  { label: 'Docs', href: 'https://kimimgo.github.io/viznoir/' },
  { label: 'Issues', href: 'https://github.com/kimimgo/viznoir/issues' },
  { label: 'License', href: 'https://github.com/kimimgo/viznoir/blob/main/LICENSE' },
  { label: 'Changelog', href: 'https://github.com/kimimgo/viznoir/blob/main/CHANGELOG.md' },
];
---

<footer class="border-t border-border/50 bg-primary">
  <div class="max-w-6xl mx-auto px-6 py-10">
    <div class="flex flex-col items-center gap-5">
      <!-- Links -->
      <nav class="flex flex-wrap justify-center gap-6">
        {links.map((link) => (
          <a
            href={link.href}
            target="_blank"
            rel="noopener noreferrer"
            class="text-sm text-text-secondary/40 hover:text-accent transition-colors"
          >
            {link.label}
          </a>
        ))}
      </nav>

      <!-- Copyright -->
      <p class="text-xs text-text-secondary/30 font-mono">
        viznoir &middot; MIT License
      </p>
    </div>
  </div>
</footer>
