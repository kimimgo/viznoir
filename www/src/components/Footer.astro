---
const links = [
  { label: 'GitHub', href: 'https://github.com/kimimgo/parapilot' },
  { label: 'PyPI', href: 'https://pypi.org/project/mcp-server-parapilot/' },
  { label: 'Issues', href: 'https://github.com/kimimgo/parapilot/issues' },
  { label: 'License', href: 'https://github.com/kimimgo/parapilot/blob/main/LICENSE' },
];
---

<footer class="border-t border-border/50 bg-primary">
  <div class="max-w-6xl mx-auto px-6 py-12">
    <div class="flex flex-col sm:flex-row items-center justify-between gap-6">
      <!-- Brand -->
      <div class="flex items-center gap-3">
        <div class="w-8 h-8 rounded-lg bg-accent/10 border border-accent/20 flex items-center justify-center">
          <svg class="w-4 h-4 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
              d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
        </div>
        <span class="text-sm font-mono text-text-secondary/50">
          parapilot &middot; MIT License
        </span>
      </div>

      <!-- Links -->
      <nav class="flex gap-6">
        {links.map((link) => (
          <a
            href={link.href}
            target="_blank"
            rel="noopener noreferrer"
            class="text-sm text-text-secondary/40 hover:text-accent transition-colors"
          >
            {link.label}
          </a>
        ))}
      </nav>
    </div>
  </div>
</footer>
