{
  "name": "viznoir",
  "description": "CAE post-processing plugin for AI coding assistants. Headless VTK rendering, mesh analysis, and automated report generation for CFD/FEA researchers.",
  "version": "0.1.0",
  "author": {
    "name": "Imgyu Kim",
    "url": "https://github.com/kimimgo"
  },
  "repository": "https://github.com/kimimgo/viznoir",
  "license": "MIT",
  "keywords": [
    "cae",
    "cfd",
    "fea",
    "vtk",
    "paraview",
    "post-processing",
    "openfoam",
    "dualsphysics",
    "simulation",
    "visualization",
    "mcp"
  ],
  "mcp": {
    "command": "mcp-server-viznoir",
    "env": {
      "VIZNOIR_OUTPUT_DIR": "/tmp/viznoir"
    }
  }
}
